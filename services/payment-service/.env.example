# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://payment:payment123@localhost:5435/payment_service"

# ─── Microservice ─────────────────────────────────────────────────────────────
PORT="3005"
NODE_ENV="development"
LOG_LEVEL="info"
INTERNAL_API_KEY="trocar-para-um-segredo-forte-em-producao"

# URL do monolito Next.js (para callbacks internos após reconciliar pagamento)
MONOLITH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
AMQP_URL="amqp://guest:guest@localhost:5672"

# ─── Mercado Pago (OAuth marketplace) ─────────────────────────────────────────
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""
MERCADOPAGO_WEBHOOK_SECRET=""

# ─── Criptografia (tokens OAuth em repouso) ───────────────────────────────────
# 32 bytes base64 — deve ser IDÊNTICO ao do monolito para migrar tokens existentes
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""
