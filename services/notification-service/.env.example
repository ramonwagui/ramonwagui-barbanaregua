# Banco próprio do Notification Service
DATABASE_URL="postgresql://postgres:password@localhost:5433/notification_service"

# RabbitMQ
AMQP_URL="amqp://guest:guest@localhost:5672"

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_TEMPLATE_LANG="pt_BR"
WHATSAPP_TEMPLATE_CONFIRMATION="barbearia_confirmacao"
WHATSAPP_TEMPLATE_REMINDER="barbearia_lembrete_botoes"
WHATSAPP_TEMPLATE_CANCELLATION="barbearia_cancelamento"
WHATSAPP_TEMPLATE_BARBER_BOOKING="barbearia_barbeiro_agendamento"
WHATSAPP_TEMPLATE_BARBER_CANCELLATION="barbearia_barbeiro_cancelamento"

# Z-API fallback global
ZAPI_CLIENT_TOKEN=""

# URL pública do app (para links de cancelamento)
APP_URL="http://localhost:3000"

# Chave para proteger a API interna
INTERNAL_API_KEY="trocar-para-um-segredo-forte"

# Servidor
PORT=3007
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development
