generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// MULTI-TENANCY CORE
// ─────────────────────────────────────────────

model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  logoUrl      String?
  phone        String?
  address      String?
  city         String?
  state        String?
  zipCode      String?
  timezone     String   @default("America/Sao_Paulo")
  primaryColor String   @default("#1a1a2e")
  isActive     Boolean  @default(true)

  // Sinal (depósito) para confirmar agendamento
  requireDeposit       Boolean @default(false)
  depositPercent       Int     @default(50) // 1–100
  depositExpiryMinutes Int     @default(20) // tempo p/ pagar o PIX antes de liberar o slot
  cancelRefundHours    Int     @default(24) // antecedência mínima p/ estorno

  // Cancelamento self-service pelo cliente (cada salão decide se habilita)
  allowClientCancellation Boolean @default(false)

  // Upsell: sugerir add-ons (serviços marcados) no agendamento
  upsellEnabled Boolean @default(false)

  // Avisar o barbeiro por WhatsApp em novos agendamentos e cancelamentos
  notifyBarberEnabled Boolean @default(false)

  // Fidelidade (cartão de carimbo): a cada N atendimentos, 1 serviço grátis
  loyaltyEnabled       Boolean @default(false)
  loyaltyThreshold     Int     @default(10) // N atendimentos p/ ganhar a recompensa
  loyaltyRewardServiceId String?            // serviço dado como recompensa

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownerId String @unique
  owner   User   @relation("TenantOwner", fields: [ownerId], references: [id])

  users          User[]          @relation("TenantUsers")
  barbers        Barber[]
  services       Service[]
  appointments   Appointment[]
  payments       Payment[]
  subscription   Subscription?
  businessHours  BusinessHour[]
  closedDays     ClosedDay[]
  notifTemplates NotifTemplate[]
  webhookSetting WebhookSetting?
  banners        Banner[]
  mercadoPago    MercadoPagoConnection?
  loyaltyCards   LoyaltyCard[]
  servicePackages ServicePackage[]
  clientPackages  ClientPackage[]

  @@index([slug])
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  TENANT_OWNER
  BARBER
  CLIENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CLIENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenantId    String?
  tenant      Tenant?  @relation("TenantUsers", fields: [tenantId], references: [id])
  ownedTenant Tenant?  @relation("TenantOwner")

  barberProfile Barber?
  accounts      Account[]
  sessions      Session[]
  appointments  Appointment[] @relation("ClientAppointments")

  @@index([tenantId])
  @@index([email])
  @@index([phone])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// BARBERS
// ─────────────────────────────────────────────

model Barber {
  id            String   @id @default(cuid())
  userId        String   @unique
  tenantId      String
  bio           String?
  avatarUrl     String?
  isActive      Boolean  @default(true)
  acceptsWalkIn Boolean  @default(true)
  commissionPercent Int  @default(0) // % de comissão do barbeiro (0–100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  services      BarberService[]
  appointments  Appointment[]
  workSchedules BarberSchedule[]
  timeBlocks    TimeBlock[]

  @@index([tenantId])
}

model BarberSchedule {
  id          String  @id @default(cuid())
  barberId    String
  dayOfWeek   Int
  startTime   String
  endTime     String
  breakStart  String?
  breakEnd    String?
  isActive    Boolean @default(true)

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
}

model TimeBlock {
  id        String   @id @default(cuid())
  barberId  String
  startAt   DateTime
  endAt     DateTime
  reason    String?
  createdAt DateTime @default(now())

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startAt])
}

// ─────────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────────

model Service {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  imageUrl        String?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  // Upsell: aparece como sugestão de add-on no agendamento
  isUpsellSuggestion Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id])
  barbers      BarberService[]
  appointments AppointmentService[]
  packages     ServicePackage[]

  @@index([tenantId])
}

model BarberService {
  barberId    String
  serviceId   String
  customPrice Decimal? @db.Decimal(10, 2)

  barber  Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
}

// ─────────────────────────────────────────────
// APPOINTMENTS
// ─────────────────────────────────────────────

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id                 String            @id @default(cuid())
  tenantId           String
  clientId           String?
  guestName          String?
  guestPhone         String?
  guestEmail         String?
  barberId           String
  status             AppointmentStatus @default(CONFIRMED)
  scheduledAt        DateTime
  endsAt             DateTime
  notes              String?
  totalPrice         Decimal           @db.Decimal(10, 2)
  depositAmount      Decimal?          @db.Decimal(10, 2) // valor do sinal cobrado
  paymentExpiresAt   DateTime?         // quando o hold PENDING (aguardando sinal) expira
  reminderSent       Boolean           @default(false)
  clientConfirmedAt  DateTime?         // cliente confirmou presença (via WhatsApp)
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  client   User?   @relation("ClientAppointments", fields: [clientId], references: [id])
  barber   Barber  @relation(fields: [barberId], references: [id])

  services AppointmentService[]
  payment  Payment?

  @@index([tenantId, scheduledAt])
  @@index([barberId, scheduledAt])
  @@index([clientId])
}

model AppointmentService {
  id              String @id @default(cuid())
  appointmentId   String
  serviceId       String
  price           Decimal @db.Decimal(10, 2)
  durationMinutes Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])
}

// ─────────────────────────────────────────────
// BUSINESS HOURS & CLOSED DAYS
// ─────────────────────────────────────────────

model BusinessHour {
  id        String  @id @default(cuid())
  tenantId  String
  dayOfWeek Int
  openTime  String
  closeTime String
  isOpen    Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dayOfWeek])
}

model ClosedDay {
  id       String   @id @default(cuid())
  tenantId String
  date     DateTime @db.Date
  reason   String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
  MERCADO_PAGO
  CASH
  PIX
}

model Payment {
  id                String          @id @default(cuid())
  tenantId          String
  // Opcional: pagamento pode ser de um agendamento (sinal) OU de um pacote.
  appointmentId     String?         @unique
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("BRL")
  status            PaymentStatus   @default(PENDING)
  provider          PaymentProvider
  providerPaymentId String?
  providerRefId     String?
  pixCode           String?
  pixQrCode         String?
  paidAt            DateTime?
  refundedAt        DateTime?
  refundAmount      Decimal?        @db.Decimal(10, 2)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  clientPackage ClientPackage?

  @@index([tenantId])
  @@index([providerPaymentId])
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS (B2B SaaS billing)
// ─────────────────────────────────────────────

enum PlanTier {
  BASIC
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  plan                 PlanTier           @default(BASIC)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

enum NotifChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotifStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

enum NotifType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER_24H
  BOOKING_REMINDER_1H
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  BARBER_NEW_BOOKING
  BARBER_CANCELLATION
}

model Notification {
  id             String       @id @default(cuid())
  tenantId       String
  appointmentId  String?
  recipientPhone String?
  recipientEmail String?
  channel        NotifChannel
  type           NotifType
  status         NotifStatus  @default(PENDING)
  body           String       @db.Text
  providerMsgId  String?
  scheduledFor   DateTime?
  sentAt         DateTime?
  errorMsg       String?
  createdAt      DateTime     @default(now())

  @@index([tenantId, type])
  @@index([scheduledFor, status])
}

model NotifTemplate {
  id           String       @id @default(cuid())
  tenantId     String
  type         NotifType
  channel      NotifChannel
  bodyTemplate String       @db.Text
  isActive     Boolean      @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, type, channel])
}

model WebhookSetting {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  zapiToken    String?
  zapiInstance String?
  twilioSid    String?
  twilioToken  String?
  resendApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ─────────────────────────────────────────────
// BANNERS DE ANÚNCIO
// ─────────────────────────────────────────────

enum BannerPosition {
  LEFT
  RIGHT
  BOTH
}

model Banner {
  id        String         @id @default(cuid())
  tenantId  String
  imageUrl  String
  clickUrl  String?
  position  BannerPosition @default(BOTH)
  isActive  Boolean        @default(true)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}

// ─────────────────────────────────────────────
// CONFIGURAÇÃO GLOBAL DA PLATAFORMA
// ─────────────────────────────────────────────

model GlobalConfig {
  id             String   @id @default("singleton")
  platformLogoUrl String?
  platformName   String   @default("Barbanaregua")
  updatedAt      DateTime @updatedAt
}

// ─────────────────────────────────────────────
// FIDELIDADE — CARTÃO DE CARIMBO POR CLIENTE
// ─────────────────────────────────────────────
// Progresso de fidelidade por (salão, telefone do cliente). A cada
// loyaltyThreshold atendimentos COMPLETED, o cliente ganha 1 recompensa
// (serviço grátis), resgatável num próximo agendamento.

model LoyaltyCard {
  id              String   @id @default(cuid())
  tenantId        String
  clientPhone     String
  clientName      String?
  completedCount  Int      @default(0)
  rewardsEarned   Int      @default(0)
  rewardsRedeemed Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientPhone])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// MERCADO PAGO — CONEXÃO OAUTH POR SALÃO (MARKETPLACE)
// ─────────────────────────────────────────────
// Cada salão conecta a própria conta do Mercado Pago via OAuth. O sinal
// (depósito) é cobrado com o access_token DO SALÃO, caindo direto na conta
// dele. Tokens são guardados CRIPTOGRAFADOS (AES-256-GCM) — ver src/lib/crypto.ts.

model MercadoPagoConnection {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  mpUserId     String // user_id do vendedor no Mercado Pago
  mpNickname   String? // p/ exibir "Conectado como ..."
  accessToken  String   @db.Text // CRIPTOGRAFADO
  refreshToken String   @db.Text // CRIPTOGRAFADO
  publicKey    String?
  expiresAt    DateTime // quando o access_token expira
  scope        String?
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PACOTES PRÉ-PAGOS (créditos de serviço comprados via PIX)
// ─────────────────────────────────────────────
// ServicePackage: pacote definido pelo dono (ex.: "4 Cortes"). ClientPackage:
// compra de um cliente (ledger de créditos), ativada quando o PIX é aprovado.

enum ClientPackageStatus {
  PENDING // aguardando pagamento do PIX
  ACTIVE // pago, com créditos disponíveis
  EXPIRED
  CANCELLED
}

model ServicePackage {
  id           String   @id @default(cuid())
  tenantId     String
  serviceId    String
  name         String
  credits      Int // quantidade de atendimentos incluídos
  price        Decimal  @db.Decimal(10, 2) // preço à vista do pacote
  validityDays Int      @default(90) // validade dos créditos após a compra
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service   Service         @relation(fields: [serviceId], references: [id])
  purchases ClientPackage[]

  @@index([tenantId])
}

model ClientPackage {
  id           String              @id @default(cuid())
  tenantId     String
  packageId    String
  serviceId    String // denormalizado: serviço coberto pelos créditos
  clientPhone  String
  clientName   String?
  creditsTotal Int
  creditsUsed  Int                 @default(0)
  status       ClientPackageStatus @default(PENDING)
  expiresAt    DateTime?
  paymentId    String?             @unique
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  package ServicePackage @relation(fields: [packageId], references: [id])
  payment Payment?       @relation(fields: [paymentId], references: [id])

  @@index([tenantId, clientPhone])
  @@index([serviceId])
}
