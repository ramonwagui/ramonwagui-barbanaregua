# ─── Database ────────────────────────────────────────────────────────────────
# Railway: copie a connection string do painel do PostgreSQL no Railway
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="seu-secret-aqui"
# URL pública do app (Railway fornece automaticamente via $RAILWAY_PUBLIC_DOMAIN)
AUTH_URL="https://seu-app.railway.app"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-app.railway.app"

# ─── Stripe (opcional) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ─── Mercado Pago (OAuth marketplace) ────────────────────────────────────────
# Cada salão conecta a PRÓPRIA conta via OAuth; o sinal cai direto na conta dele.
# Credenciais do app marketplace da PLATAFORMA (Painel MP → sua aplicação):
MERCADOPAGO_CLIENT_ID=""
MERCADOPAGO_CLIENT_SECRET=""
# Secret da assinatura do webhook (Mercado Pago → Webhooks → "Chave secreta").
# Sem ele, a validação de assinatura é pulada (não recomendado em produção).
MERCADOPAGO_WEBHOOK_SECRET=""

# ─── Criptografia ─────────────────────────────────────────────────────────────
# 32 bytes base64 p/ criptografar os tokens OAuth dos salões em repouso.
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# ─── WhatsApp Cloud API (oficial Meta — número central da plataforma) ─────────
# Provider principal de notificações. Envia via TEMPLATES aprovados.
WHATSAPP_ACCESS_TOKEN=""        # token permanente de System User
WHATSAPP_PHONE_NUMBER_ID=""     # ID do número (WhatsApp Manager / API Setup)
# Opcionais (webhook de status/resposta):
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""
# Opcionais (sobrescrever nomes dos templates / idioma):
# WHATSAPP_TEMPLATE_CONFIRMATION="barbearia_confirmacao"
# WHATSAPP_TEMPLATE_REMINDER="barbearia_lembrete"
# WHATSAPP_TEMPLATE_CANCELLATION="barbearia_cancelamento"
# WHATSAPP_TEMPLATE_LANG="pt_BR"

# ─── Z-API WhatsApp (fallback por salão, opcional) ───────────────────────────
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""

# ─── Resend Email (opcional) ─────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@seudominio.com.br"

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET="secret-aleatorio-para-proteger-o-cron"
